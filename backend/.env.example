# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database ---
# Local dev uses docker-compose; this matches that default.
DATABASE_URL=postgres://oprams:oprams@localhost:5432/oprams

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Frontend origin (for CORS + cookie scope) ---
# In dev, if you use `npx serve frontend`, it runs on port 3001 by default — set that here.
FRONTEND_ORIGIN=http://localhost:3001

# --- Session ---
# 32+ random bytes, base64. Generate with:  openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# --- First admin (used by `npm run seed`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login
